{
  "name": "thorchain-wiki",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/start-standalone.mjs",
    "start:next": "next start",
    "start:standalone": "node scripts/start-standalone.mjs",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:visual": "playwright test tests/smoke.spec.ts -g \"visually safe\"",
    "test:e2e:csp": "CSP_ENFORCE=1 playwright test tests/smoke.spec.ts -g \"security headers are present|normal page loads do not emit CSP reports\"",
    "generate:search": "node scripts/generate-mdx-search.mjs",
    "check:content": "node scripts/generate-mdx-search.mjs --check && node scripts/check-curated-data.mjs",
    "check:live-snapshot": "node scripts/check-live-chain-snapshot.mjs",
    "smoke:standalone": "node scripts/smoke-standalone.mjs",
    "audit:prod": "npm audit --omit=dev --audit-level=moderate",
    "audit:all": "npm audit --audit-level=moderate",
    "check:runtime-url": "node scripts/check-runtime-url.mjs"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.10",
    "@tailwindcss/typography": "^0.5.20",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.23.0",
    "lunr": "^2.3.9",
    "next": "^16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^3.9.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/lunr": "^2.3.7",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "jiti": "^2.7.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
