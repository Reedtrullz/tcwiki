{
  "name": "thorchain-wiki",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "node scripts/require-node22.mjs && next dev",
    "build": "node scripts/require-node22.mjs && next build",
    "start": "node scripts/require-node22.mjs && node scripts/start-standalone.mjs",
    "start:next": "node scripts/require-node22.mjs && next start",
    "start:standalone": "node scripts/require-node22.mjs && node scripts/start-standalone.mjs",
    "lint": "node scripts/require-node22.mjs && eslint",
    "typecheck": "node scripts/require-node22.mjs && tsc --noEmit",
    "pretest:unit": "node scripts/require-node22.mjs && node scripts/clean-platform-artifacts.mjs",
    "test:unit": "node scripts/require-node22.mjs && vitest run",
    "test:unit:watch": "node scripts/require-node22.mjs && vitest",
    "test:e2e": "node scripts/require-node22.mjs && playwright test",
    "test:e2e:docker-smoke": "node scripts/require-node22.mjs && playwright test tests/runtime.spec.ts tests/home.spec.ts tests/network.spec.ts tests/dynamic-fees.spec.ts tests/economics.spec.ts tests/stats.spec.ts --project=chromium -g \"@docker-smoke\"",
    "test:e2e:visual": "node scripts/require-node22.mjs && playwright test tests/visual-safety.spec.ts tests/deep-dives.spec.ts -g \"visually safe\"",
    "test:e2e:links": "node scripts/require-node22.mjs && playwright test tests/link-integrity.spec.ts --project=chromium",
    "test:e2e:csp": "node scripts/require-node22.mjs && CSP_ENFORCE=1 playwright test tests/runtime.spec.ts tests/routes.spec.ts -g \"security headers are present|normal page loads do not emit CSP reports\"",
    "check:release-tracked": "node scripts/require-node22.mjs && node scripts/check-release-tracked.mjs",
    "generate:search": "node scripts/require-node22.mjs && node scripts/generate-mdx-search.mjs",
    "check:content": "node scripts/require-node22.mjs && node scripts/generate-mdx-search.mjs --check && node scripts/check-curated-data.mjs",
    "check:live-snapshot": "node scripts/require-node22.mjs && node scripts/check-live-chain-snapshot.mjs",
    "smoke:standalone": "node scripts/require-node22.mjs && node scripts/smoke-standalone.mjs",
    "smoke:docker": "node scripts/require-node22.mjs && node scripts/smoke-docker-runtime.mjs",
    "audit:prod": "node scripts/require-node22.mjs && npm audit --omit=dev --audit-level=moderate",
    "audit:all": "node scripts/require-node22.mjs && npm audit --audit-level=moderate",
    "check:runtime-url": "node scripts/require-node22.mjs && node scripts/check-runtime-url.mjs"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.10",
    "@tailwindcss/typography": "^0.5.20",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.24.0",
    "lunr": "^2.3.9",
    "next": "^16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^3.9.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/lunr": "^2.3.7",
    "@types/node": "^22.20.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "axe-core": "^4.12.1",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "jiti": "^2.7.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
